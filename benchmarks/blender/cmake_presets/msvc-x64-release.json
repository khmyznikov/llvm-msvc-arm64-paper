{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "msvc-x64-release",
            "displayName": "MSVC x64 Release (no LTCG)",
            "description": "Visual Studio 2022 generator, x64, Release. No LTCG/LTO, no PGO.",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "WITH_CYCLES_CUDA_BINARIES": "OFF",
                "WITH_CYCLES_HIP_BINARIES": "OFF",
                "WITH_CYCLES_ONEAPI_BINARIES": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc-x64-release",
            "configurePreset": "msvc-x64-release",
            "configuration": "Release"
        }
    ]
}
